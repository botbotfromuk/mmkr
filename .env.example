# mmkr — environment configuration
# Copy to .env and fill in real values. NEVER commit .env to git.

# Required
ANTHROPIC_API_KEY=sk-ant-...
GH_TOKEN=ghp_...
TG_BOT_TOKEN=...
CREATOR_ID=123456789

# Wallet — choose ONE approach:
# Option A: provide address + private key directly
WALLET_ADDRESS=0x...
WALLET_PRIVATE_KEY=0x...

# Option B: derive from BIP39 mnemonic
# WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Optional secrets injected into agent context
SECRET_EMAIL_PASSWORD=
SECRET_ATOMICMAIL_SEED=

# Data directory (default: /agent-data)
# MMKR_DATA=/agent-data
